{
  "rewrites": [
    { "source": "/((?!api/|long-light/).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/((?!assets/|logos/|long-light/).*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    }
  ]
}
